{
"manifest_version": 3,
  "name": "Song Lyric Romanizer",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://music.youtube.com/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Open Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/dict/*"],
      "matches": ["https://music.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": [
        "lib/kuromoji.js",
        "lib/kuroshiro.min.js",
        "lib/kuroshiro-analyzer-kuromoji.min.js",
        "lib/index.min.js",
        "lib/hangul-romanize.min.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}